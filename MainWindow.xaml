<Window x:Class="CSharpEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:local="clr-namespace:CSharpEditor"
        Title="C# Code Editor"
        Height="700" Width="1100"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Window.Resources>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3E3E3E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#505050"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RunButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Foreground" Value="#4EC9B0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="StopButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Foreground" Value="#F44747"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#2D2D2D" BorderBrush="#3F3F3F" BorderThickness="0,0,0,1" Padding="4,2">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button x:Name="BtnNew" Content="&#x2795; Novo"
                            Style="{StaticResource ToolbarButton}"
                            Click="BtnNew_Click" ToolTip="Novo arquivo (Ctrl+N)"/>
                    <Button x:Name="BtnOpen" Content="&#x1F4C2; Abrir"
                            Style="{StaticResource ToolbarButton}"
                            Click="BtnOpen_Click" ToolTip="Abrir arquivo (Ctrl+O)"/>
                    <Button x:Name="BtnSave" Content="&#x1F4BE; Salvar"
                            Style="{StaticResource ToolbarButton}"
                            Click="BtnSave_Click" ToolTip="Salvar arquivo (Ctrl+S)"/>

                    <Border Width="1" Background="#3F3F3F" Margin="8,4"/>

                    <Button x:Name="BtnRun" Content="&#x25B6; Executar"
                            Style="{StaticResource RunButton}"
                            Click="BtnRun_Click" ToolTip="Compilar e executar (F5)"/>
                    <Button x:Name="BtnStop" Content="&#x25A0; Parar"
                            Style="{StaticResource StopButton}"
                            Click="BtnStop_Click" ToolTip="Parar execução"
                            IsEnabled="False"/>
                </StackPanel>

                <TextBlock x:Name="TxtStatus" DockPanel.Dock="Right"
                           Foreground="#888888" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,12,0"
                           HorizontalAlignment="Right"
                           FontFamily="Segoe UI"
                           Text="Pronto"/>
            </DockPanel>
        </Border>

        <!-- Code Editor -->
        <avalonEdit:TextEditor
            Grid.Row="1"
            x:Name="CodeEditor"
            FontFamily="Cascadia Code, Consolas, Courier New"
            FontSize="14"
            ShowLineNumbers="True"
            Background="#1E1E1E"
            Foreground="#D4D4D4"
            LineNumbersForeground="#858585"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto"
            Padding="8,4"/>

        <!-- GridSplitter -->
        <GridSplitter Grid.Row="2" Height="5"
                      HorizontalAlignment="Stretch"
                      Background="#2D2D2D"
                      ResizeBehavior="PreviousAndNext"
                      Cursor="SizeNS"/>

        <!-- Terminal Output -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#252526" Padding="10,5">
                <DockPanel>
                    <TextBlock Text="Terminal" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Segoe UI" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button x:Name="BtnClearTerminal" Content="Limpar"
                            Style="{StaticResource ToolbarButton}"
                            Click="BtnClearTerminal_Click"
                            DockPanel.Dock="Right" HorizontalAlignment="Right"
                            FontSize="11"/>
                </DockPanel>
            </Border>

            <TextBox Grid.Row="1"
                     x:Name="TerminalOutput"
                     IsReadOnly="True"
                     Background="#1E1E1E"
                     Foreground="#CCCCCC"
                     FontFamily="Cascadia Code, Consolas, Courier New"
                     FontSize="13"
                     BorderThickness="0"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     Padding="10,6"
                     AcceptsReturn="True"/>
        </Grid>
    </Grid>
</Window>
